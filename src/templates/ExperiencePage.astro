---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import { experienceEntries } from '../data/experience';
import { getPageTitle, type SiteTranslations } from '../i18n/translations/site';
import type { Locale } from '../i18n/locales';

interface Props {
    locale: Locale;
    t: SiteTranslations;
}

const { locale, t } = Astro.props;
---
<BaseLayout title={getPageTitle(locale, t.experience.title)} locale={locale}>
    <section class="py-16">
        <div class="mx-auto max-w-6xl px-4">
            <SectionHeader title={t.experience.title} subtitle={t.experience.subtitle} />
            <p class="mb-8 max-w-3xl text-sm leading-relaxed text-body">{t.experience.intro}</p>
            <ExperienceTimeline entries={experienceEntries} />
        </div>
    </section>
</BaseLayout>
