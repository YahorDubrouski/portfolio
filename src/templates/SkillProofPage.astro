---
import DockerProofPage from './proofs/DockerProofPage.astro';
import type { Locale } from '../i18n/locales';

interface Props {
    locale: Locale;
    slug: string;
}

const { locale, slug } = Astro.props;
---
{slug === 'docker' ? (
    <DockerProofPage locale={locale} />
) : (
    <p class="mx-auto max-w-6xl px-4 py-16 text-body">Skill proof page not found.</p>
)}
