---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ReviewCard from '../components/ReviewCard.astro';
import { getReviews } from '../data/reviews';
import { getReviewsForRolePage } from '../data/roleLanding';
import { getPageTitle, type HireRole, type SiteTranslations } from '../i18n/translations/site';
import type { Locale } from '../i18n/locales';

interface Props {
    locale: Locale;
    t: SiteTranslations;
    /** When set, only role-matching reviews are shown (`/hire/{role}/reviews`). */
    role?: HireRole;
}

const { locale, t, role } = Astro.props;
const reviews = role ? getReviewsForRolePage(role, locale) : getReviews(locale);
const landingCopy = role ? t.hire[role].landing : undefined;
const pageTitle = landingCopy?.reviewsPageTitle ?? t.reviews.title;
const pageSubtitle = landingCopy?.reviewsSubtitle ?? t.reviews.subtitle;
---
<BaseLayout title={getPageTitle(locale, pageTitle)} locale={locale}>
    <section class="py-16">
        <div class="mx-auto max-w-6xl px-4">
            <SectionHeader title={pageTitle} subtitle={pageSubtitle} />
            <div class="grid gap-6 md:grid-cols-2">
                {reviews.map((review) => (
                    <ReviewCard review={review} locale={locale} />
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
