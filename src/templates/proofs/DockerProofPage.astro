---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';
import DockerExamplesSection from '../../components/proofs/DockerExamplesSection.astro';
import ProofSectionHeader from '../../components/proofs/ProofSectionHeader.astro';
import { dockerProofPage as content } from '../../data/proofPages/docker';
import { localizedPath } from '../../i18n/paths';
import { getPageTitle } from '../../i18n/translations/site';
import type { Locale } from '../../i18n/locales';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const pageTitle = getPageTitle(locale, `${content.title} — skill proof`);
const { caseStudy, architecture } = content;
---
<BaseLayout title={pageTitle} locale={locale}>
    <section class="py-10 sm:py-12">
        <div class="mx-auto max-w-6xl px-4">
            <nav class="mb-5 text-sm text-stone-500">
                <a href={localizedPath('/capabilities', locale)} class="hover:text-stone-800">Skills proof</a>
                <span aria-hidden="true"> / </span>
                <span class="text-stone-700">{content.title}</span>
            </nav>

            <ProofSectionHeader
                kicker="Production case study"
                title={caseStudy.title}
                description={caseStudy.verdict}
                headingLevel="h1"
            >
                <ul class="mt-4 flex flex-wrap gap-2">
                    {caseStudy.chips.map((chip) => (
                        <li class="tag text-xs font-medium uppercase tracking-wide">{chip}</li>
                    ))}
                </ul>
                <p class="mt-3 max-w-5xl text-sm leading-relaxed text-stone-500">{caseStudy.heroNote}</p>
            </ProofSectionHeader>

            <div class="mt-6 space-y-5">
                <section class="card overflow-hidden p-0">
                    <div class="border-b border-border px-5 py-4">
                        <h2 class="text-lg font-semibold text-heading">{architecture.heading}</h2>
                    </div>

                    <div class="px-5 py-4">
                        <h3 class="text-sm font-semibold uppercase tracking-wide text-stone-500">
                            {architecture.diagramLabel}
                        </h3>
                        <img
                            src="/proof/docker-swarm-topology.svg"
                            alt="Docker Swarm stack with replicated web, scheduler, and queue-worker services on an overlay network"
                            class="mx-auto mt-3 w-full max-w-4xl"
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>

                    <div class="border-t border-border">
                        <h3 class="mb-3 px-5 pt-4 text-sm font-semibold uppercase tracking-wide text-stone-500">
                            {architecture.templateLabel}
                        </h3>
                        <CodeSnippet
                            embedded
                            code={architecture.code}
                            caption={architecture.templateCaption}
                        />
                    </div>
                </section>

                <section class="card border-stone-300 p-5">
                    <h2 class="text-lg font-semibold text-heading">{content.achievedOutcomes.heading}</h2>
                    <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-body">
                        {content.achievedOutcomes.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </section>
            </div>
        </div>
    </section>

    <DockerExamplesSection {...content.dockerElsewhere} />
</BaseLayout>
