---
import type { ExperienceEntry } from '../data/experience';

interface Props {
    entries: ExperienceEntry[];
}

const { entries } = Astro.props;
---
<div class="space-y-8">
    {
        entries.map((entry) => (
            <article class="card">
                <header>
                    <h3 class="font-serif text-xl font-semibold text-heading">{entry.role}</h3>
                    <p class="mt-1 text-sm font-medium text-body">{entry.company}</p>
                    <p class="mt-2 text-sm text-muted">
                        {entry.period}
                        {' · '}
                        {entry.location}
                        {' · '}
                        {entry.workMode}
                    </p>
                    <p class="mt-1 text-sm text-muted">{entry.domain}</p>
                </header>

                {
                    entry.roleHistory && entry.roleHistory.length > 0 && (
                        <p class="mt-3 text-sm leading-relaxed text-body">
                            {entry.roleHistory.map((role) => `${role.title} (${role.period})`).join(' → ')}
                        </p>
                    )
                }

                <p class="mt-4 text-sm leading-6 text-body">{entry.summary}</p>

                {
                    entry.highlights && entry.highlights.length > 0 && (
                        <section class="mt-5">
                            <h4 class="text-xs font-semibold uppercase tracking-widest text-muted">Key outcomes</h4>
                            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-body">
                                {entry.highlights.map((highlight) => (
                                    <li class="flex gap-2">
                                        <span class="mt-2 h-px w-3 shrink-0 bg-border-strong" aria-hidden="true" />
                                        <span>
                                            <span class="font-semibold text-heading">{highlight.value}</span>
                                            {' — '}
                                            {highlight.label}
                                        </span>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )
                }

                <section class="mt-5">
                    <h4 class="text-xs font-semibold uppercase tracking-widest text-muted">Responsibilities</h4>
                    <ul class="mt-3 space-y-2 text-sm leading-relaxed text-body">
                        {entry.responsibilities.map((item) => (
                            <li class="flex gap-2">
                                <span class="mt-2 h-px w-3 shrink-0 bg-border-strong" aria-hidden="true" />
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </section>

                {
                    (entry.projects ?? []).length > 0 && (
                        <section class="mt-5">
                            <h4 class="text-xs font-semibold uppercase tracking-widest text-muted">Projects</h4>
                            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-body">
                                {(entry.projects ?? []).map((project) => (
                                    <li class="flex gap-2">
                                        <span class="mt-2 h-px w-3 shrink-0 bg-border-strong" aria-hidden="true" />
                                        <span>
                                            <span class="font-medium text-heading">{project.name}.</span>{' '}
                                            {project.description}
                                        </span>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )
                }

                <section class="mt-5">
                    <h4 class="text-xs font-semibold uppercase tracking-widest text-muted">Technologies</h4>
                    <div class="mt-3 flex flex-wrap gap-2">
                        {entry.technologies.map((tech) => (
                            <span class="tag text-xs">{tech}</span>
                        ))}
                    </div>
                </section>

                {
                    entry.leadership && entry.leadership.length > 0 && (
                        <p class="mt-4 text-xs text-muted">
                            <span class="font-semibold text-heading">Leadership:</span>{' '}
                            {entry.leadership.join(' · ')}
                        </p>
                    )
                }
            </article>
        ))
    }
</div>
