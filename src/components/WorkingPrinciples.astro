---
import HomeSectionHeader from './HomeSectionHeader.astro';

export interface PrincipleItem {
    title: string;
    body: string;
}

interface Props {
    title: string;
    subtitle?: string;
    principles: PrincipleItem[];
    linkHref?: string;
    linkLabel?: string;
}

const { title, subtitle, principles, linkHref, linkLabel } = Astro.props;
---
<section class="border-b border-border bg-surface-muted py-16">
    <div class="mx-auto max-w-6xl px-4">
        <HomeSectionHeader title={title} subtitle={subtitle} linkHref={linkHref} linkLabel={linkLabel} />
        <ol class="grid gap-5 sm:grid-cols-2">
            {
                principles.map((principle, index) => (
                    <li class="card-interactive border-l-4 border-l-accent">
                        <p class="text-xs font-semibold tabular-nums tracking-widest text-accent">
                            {String(index + 1).padStart(2, '0')}
                        </p>
                        <h3 class="mt-2 font-serif text-lg font-semibold text-heading">{principle.title}</h3>
                        <p class="mt-2 text-sm leading-relaxed text-body">{principle.body}</p>
                    </li>
                ))
            }
        </ol>
    </div>
</section>
