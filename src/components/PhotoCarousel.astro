---
export interface CarouselSlide {
    src: string;
    alt: string;
    width?: number;
    height?: number;
    caption?: string;
}

interface Props {
    slides: CarouselSlide[];
    id?: string;
    aspectClass?: string;
    maxHeightClass?: string;
    imageClass?: string;
    lightbox?: boolean;
}

const {
    slides,
    id = `photo-carousel-${Math.random().toString(36).slice(2, 9)}`,
    aspectClass = 'aspect-[16/10]',
    maxHeightClass = 'max-h-[190px] sm:max-h-[250px] md:max-h-[300px] lg:max-h-[340px]',
    imageClass = 'h-full w-full object-cover object-top',
    lightbox = true,
} = Astro.props;

const arrowButtonClass =
    'flex h-10 w-8 shrink-0 items-center justify-center text-heading transition hover:text-accent disabled:pointer-events-none disabled:opacity-25 sm:h-12 sm:w-10';
---

<div class="photo-carousel" data-photo-carousel={id} data-lightbox={lightbox ? 'true' : 'false'}>
    <div class="flex items-center gap-1 sm:gap-2">
        <button type="button" class={arrowButtonClass} data-carousel-prev aria-label="Previous photos">
            <svg class="h-6 w-6 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                    d="M15 5 L8 12 L15 19"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="square"
                    stroke-linejoin="miter"
                ></path>
            </svg>
        </button>

        <div class="min-w-0 flex-1 overflow-hidden" data-carousel-viewport>
            <div class="flex gap-1 transition-transform duration-300 ease-out will-change-transform" data-carousel-track>
                {slides.map((slide, slideIndex) => (
                    <div class="flex shrink-0 flex-col" data-carousel-slide>
                        <div
                            class:list={[
                                'relative overflow-hidden rounded-lg border border-border bg-surface-muted',
                                aspectClass,
                                maxHeightClass,
                            ]}
                        >
                            <img
                                src={slide.src}
                                alt={slide.alt}
                                width={slide.width}
                                height={slide.height}
                                class:list={[imageClass, lightbox && 'cursor-zoom-in']}
                                loading="lazy"
                            />
                            {lightbox && (
                                <button
                                    type="button"
                                    data-carousel-lightbox-open={slideIndex}
                                    class="absolute right-2 bottom-2 z-10 flex h-8 w-8 items-center justify-center rounded-full border border-white/60 bg-stone-900 text-white shadow-md transition hover:bg-stone-800 sm:h-9 sm:w-9"
                                    aria-label={`Open ${slide.alt} in full page`}
                                >
                                    <svg
                                        class="h-3.5 w-3.5 sm:h-4 sm:w-4"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        aria-hidden="true"
                                    >
                                        <path
                                            d="M8 3H5a2 2 0 0 0-2 2v3M16 3h3a2 2 0 0 1 2 2v3M8 21H5a2 2 0 0 1-2-2v-3M16 21h3a2 2 0 0 0 2-2v-3"
                                            stroke="currentColor"
                                            stroke-width="1.75"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        ></path>
                                    </svg>
                                </button>
                            )}
                        </div>
                        {slide.caption ? (
                            <p class="mt-3 px-1 text-center text-sm leading-relaxed text-muted">{slide.caption}</p>
                        ) : null}
                    </div>
                ))}
            </div>
        </div>

        <button type="button" class={arrowButtonClass} data-carousel-next aria-label="Next photos">
            <svg class="h-6 w-6 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                    d="M9 5 L16 12 L9 19"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="square"
                    stroke-linejoin="miter"
                ></path>
            </svg>
        </button>
    </div>

    {lightbox && (
        <div
            class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/92 p-2 sm:p-3"
            data-lightbox-overlay
            role="dialog"
            aria-modal="true"
            aria-label="Full size image preview"
            hidden
        >
            <button
                type="button"
                class="fixed right-4 top-4 z-[110] flex h-11 w-11 items-center justify-center rounded-full border border-white/20 bg-white text-2xl font-light leading-none text-stone-900 shadow-lg transition hover:bg-stone-100 sm:right-6 sm:top-6"
                data-lightbox-close
                aria-label="Close full size image"
            >
                ×
            </button>
            <img class="h-auto max-h-[96vh] w-auto max-w-[96vw] object-contain" data-lightbox-fullscreen alt="" />
        </div>
    )}
</div>

<script>
    function getVisibleCount() {
        if (window.matchMedia('(min-width: 768px)').matches) return 3;
        if (window.matchMedia('(min-width: 640px)').matches) return 2;
        return 1;
    }

    function initPhotoCarousel(root) {
        if (root.dataset.photoCarouselReady === 'true') {
            return;
        }

        const viewport = root.querySelector('[data-carousel-viewport]');
        const track = root.querySelector('[data-carousel-track]');
        const prevButton = root.querySelector('[data-carousel-prev]');
        const nextButton = root.querySelector('[data-carousel-next]');
        const slideElements = root.querySelectorAll('[data-carousel-slide]');

        if (!viewport || !track || !prevButton || !nextButton || slideElements.length === 0) {
            return;
        }

        let index = 0;
        const gap = 4;

        function getMaxIndex() {
            return Math.max(0, slideElements.length - getVisibleCount());
        }

        function update() {
            const visibleCount = getVisibleCount();
            const maxIndex = getMaxIndex();
            index = Math.min(index, maxIndex);

            const viewportWidth = viewport.clientWidth;
            const slideWidth = (viewportWidth - gap * (visibleCount - 1)) / visibleCount;

            slideElements.forEach((slide) => {
                slide.style.width = `${slideWidth}px`;
            });

            track.style.transform = `translateX(-${index * (slideWidth + gap)}px)`;

            prevButton.disabled = index === 0;
            nextButton.disabled = index >= maxIndex;
        }

        prevButton.addEventListener('click', () => {
            if (index > 0) {
                index -= 1;
                update();
            }
        });

        nextButton.addEventListener('click', () => {
            if (index < getMaxIndex()) {
                index += 1;
                update();
            }
        });

        window.addEventListener('resize', update);
        update();

        if (root.dataset.lightbox === 'true') {
            initCarouselLightbox(root);
        }

        root.dataset.photoCarouselReady = 'true';
    }

    function initCarouselLightbox(root) {
        const overlay = root.querySelector('[data-lightbox-overlay]');
        const fullscreenImg = root.querySelector('[data-lightbox-fullscreen]');
        const closeButton = root.querySelector('[data-lightbox-close]');
        const images = [...root.querySelectorAll('[data-carousel-slide] img')];

        if (!overlay || !fullscreenImg || images.length === 0) {
            return;
        }

        function openLightbox(index) {
            const image = images[index];
            fullscreenImg.src = image.src;
            fullscreenImg.alt = image.alt;
            overlay.hidden = false;
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            overlay.hidden = true;
            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
            document.body.style.overflow = '';
        }

        images.forEach((image, index) => {
            image.addEventListener('click', () => openLightbox(index));
        });

        root.querySelectorAll('[data-carousel-lightbox-open]').forEach((button) => {
            button.addEventListener('click', (event) => {
                event.stopPropagation();
                const index = Number(button.getAttribute('data-carousel-lightbox-open'));
                openLightbox(index);
            });
        });

        closeButton?.addEventListener('click', closeLightbox);

        overlay.addEventListener('click', (event) => {
            if (event.target === overlay) {
                closeLightbox();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (overlay.hidden) {
                return;
            }

            if (event.key === 'Escape') {
                closeLightbox();
            }
        });
    }

    function initAllPhotoCarousels() {
        document.querySelectorAll('[data-photo-carousel]').forEach(initPhotoCarousel);
    }

    initAllPhotoCarousels();
    document.addEventListener('astro:page-load', initAllPhotoCarousels);
</script>
