---
interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---
<div class="mb-8">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h2>
    {subtitle && <p class="mt-2 max-w-3xl text-sm leading-relaxed text-muted">{subtitle}</p>}
</div>
