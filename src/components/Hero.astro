---
export interface HeroProofBadge {
    label: string;
    href?: string;
}

interface Props {
    identityLine?: string;
    headline: string;
    proofBadges?: HeroProofBadge[];
    photoSrc?: string;
    photoAlt?: string;
}

const { identityLine, headline, proofBadges = [], photoSrc, photoAlt = '' } = Astro.props;
---
<section class="hero-band border-b border-border py-14 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-6xl px-4">
        <div class:list={['gap-10 lg:gap-12', photoSrc && 'grid lg:grid-cols-[1fr_auto] lg:items-center']}>
            {
                photoSrc && (
                    <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
                        <div class="relative">
                            <div class="absolute -inset-1 rounded-[1.25rem] bg-gradient-to-br from-accent/30 to-accent/5" aria-hidden="true" />
                            <img
                                src={photoSrc}
                                alt={photoAlt}
                                width={256}
                                height={256}
                                class="relative h-52 w-52 rounded-2xl object-cover shadow-lg ring-1 ring-border sm:h-60 sm:w-60"
                                loading="eager"
                            />
                        </div>
                    </div>
                )
            }
            <div class="order-2 max-w-2xl lg:order-1">
                {identityLine && (
                    <p class="text-sm font-semibold text-heading">{identityLine}</p>
                )}
                <h1 class="mt-2 text-3xl font-bold leading-tight tracking-tight text-heading sm:text-4xl lg:text-[2.75rem] lg:leading-[1.12]">
                    {headline}
                </h1>
                {
                    proofBadges.length > 0 && (
                        <ul class="mt-6 flex flex-wrap gap-2" aria-label="Credentials">
                            {proofBadges.map((badge) => (
                                <li>
                                    {
                                        badge.href ? (
                                            <a
                                                href={badge.href}
                                                class="inline-flex rounded-md bg-accent-muted px-2.5 py-1 text-xs font-semibold text-accent transition hover:bg-accent/10"
                                            >
                                                {badge.label}
                                            </a>
                                        ) : (
                                            <span class="inline-flex rounded-md bg-accent-muted px-2.5 py-1 text-xs font-semibold text-accent">
                                                {badge.label}
                                            </span>
                                        )
                                    }
                                </li>
                            ))}
                        </ul>
                    )
                }
                <div class="mt-8">
                    <slot name="actions" />
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-band {
        background:
            linear-gradient(135deg, var(--surface-muted) 0%, var(--surface) 55%, var(--accent-muted) 100%);
    }
</style>
