---
interface Props {
    label: string;
    blurb: string;
    href: string;
    thumbnail: string;
    thumbnailAlt: string;
    linkLabel?: string;
}

const { label, blurb, href, thumbnail, thumbnailAlt, linkLabel = 'View on GitHub →' } = Astro.props;
const isExternal = href.startsWith('http');
---
<article class="card overflow-hidden">
    <a
        href={href}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener noreferrer' : undefined}
        class="group block"
    >
        <div class="aspect-[16/9] overflow-hidden bg-stone-100">
            <img
                src={thumbnail}
                alt={thumbnailAlt}
                class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.02]"
                loading="lazy"
            />
        </div>
        <div class="p-4">
            <h3 class="text-base font-semibold text-heading group-hover:text-stone-700">{label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-body">{blurb}</p>
            <p class="mt-3 text-xs font-medium uppercase tracking-wide text-stone-500">
                {linkLabel}
            </p>
        </div>
    </a>
</article>
