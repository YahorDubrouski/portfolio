---
import { localizedPath } from '../i18n/paths';
import { isCaseStudySlug, type CachedProject } from '../data/projects';
import { getGitHubUrl } from '../data/github';
import type { Locale } from '../i18n/locales';

interface Props {
    capabilities: { name: string; projects: CachedProject[] }[];
    locale: Locale;
}

const { capabilities, locale } = Astro.props;

function projectHref(project: CachedProject): string {
    if (isCaseStudySlug(project.id)) {
        return localizedPath(`/projects/${project.id}`, locale);
    }

    const github = getGitHubUrl(project.id);
    return github ?? localizedPath('/projects', locale);
}
---
<div class="space-y-4">
    {capabilities.map((capability) => (
        <article class="card">
            <div class="flex flex-wrap items-start justify-between gap-3">
                <h3 class="text-lg font-semibold capitalize">{capability.name}</h3>
                <span class="text-xs uppercase tracking-wide text-stone-500">
                    {capability.projects.length} proof item(s)
                </span>
            </div>
            <ul class="mt-4 flex flex-wrap gap-2">
                {capability.projects.map((project) => (
                    <li>
                        <a
                            href={projectHref(project)}
                            target={projectHref(project).startsWith('http') ? '_blank' : undefined}
                            rel={projectHref(project).startsWith('http') ? 'noopener noreferrer' : undefined}
                            class="tag hover:border-stone-400 hover:bg-stone-100"
                        >
                            {project.name}
                        </a>
                    </li>
                ))}
            </ul>
        </article>
    ))}
</div>
