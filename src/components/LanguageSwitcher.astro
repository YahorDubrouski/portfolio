---
import { localeLabels, locales, type Locale } from '../i18n/locales';
import { localizedPath } from '../i18n/paths';

interface Props {
    currentLocale: Locale;
}

const { currentLocale } = Astro.props;
const currentPath = Astro.url.pathname;
const otherLocales = locales.filter((locale) => locale !== currentLocale);
---
<details class="lang-switcher relative">
    <summary class="inline-flex h-10 min-w-10 cursor-pointer select-none list-none items-center justify-center gap-0.5 rounded-md px-2 text-sm font-medium text-body transition hover:bg-surface-muted hover:text-accent">
        {localeLabels[currentLocale]}
        <svg class="h-3.5 w-3.5 opacity-60" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 10.94l3.71-3.71a.75.75 0 1 1 1.06 1.06l-4.24 4.25a.75.75 0 0 1-1.06 0L5.21 8.29a.75.75 0 0 1 .02-1.08z" clip-rule="evenodd" />
        </svg>
    </summary>
    <ul class="absolute right-0 top-full z-50 mt-1 min-w-[3rem] rounded-md border border-border bg-surface py-1 shadow-sm">
        {otherLocales.map((locale) => (
            <li>
                <a
                    href={localizedPath(currentPath, locale)}
                    hreflang={locale}
                    class="block px-3 py-1.5 text-center text-sm font-medium hover:bg-surface-muted hover:text-accent"
                >
                    {localeLabels[locale]}
                </a>
            </li>
        ))}
    </ul>
</details>

<style>
    .lang-switcher summary::-webkit-details-marker {
        display: none;
    }

    .lang-switcher:not([open]) ul {
        display: none;
    }
</style>
