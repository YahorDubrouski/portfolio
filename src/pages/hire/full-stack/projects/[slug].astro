---
import CaseStudyRouter from '../../../../components/CaseStudyRouter.astro';
import { caseStudySlugs } from '../../../../data/projects';

export function getStaticPaths() {
    return caseStudySlugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
    throw new Error('Missing project slug');
}
---
<CaseStudyRouter locale="en" slug={slug} />
