---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { defaultLocale, type Locale } from '../i18n/locales';
import { getSiteTranslations } from '../i18n/translations/site';
import { getCanonicalUrl, getHreflangAlternates, getSiteOrigin } from '../data/seo';

interface Props {
    title?: string;
    description?: string;
    locale?: Locale;
    jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, locale = defaultLocale, jsonLd } = Astro.props;
const t = getSiteTranslations(locale);
const pageTitle = title ?? t.meta.defaultTitle;
const pageDescription = description ?? t.meta.defaultDescription;
const siteOrigin = getSiteOrigin();
const canonicalUrl = getCanonicalUrl(Astro.url.pathname, siteOrigin);
const hreflangAlternates = getHreflangAlternates(Astro.url.pathname, siteOrigin);
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang={locale}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <meta name="description" content={pageDescription} />
        <meta name="author" content={t.meta.siteName} />
        <title>{pageTitle}</title>
        {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
        {
            hreflangAlternates.map(({ locale: altLocale, href }) => (
                <link rel="alternate" hreflang={altLocale} href={href} />
            ))
        }
        {canonicalUrl && <link rel="alternate" hreflang="x-default" href={canonicalUrl} />}
        <meta property="og:type" content="website" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:site_name" content={t.meta.siteName} />
        <meta property="og:locale" content={locale === 'ru' ? 'ru_RU' : 'en_US'} />
        {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
        {
            jsonLdBlocks.map((block) => (
                <script type="application/ld+json" set:html={JSON.stringify(block)} />
            ))
        }
    </head>
    <body class="flex min-h-screen flex-col bg-background antialiased">
        <SiteHeader locale={locale} />
        <main id="main-content" class="flex-1">
            <slot />
        </main>
        <SiteFooter locale={locale} />
    </body>
</html>
